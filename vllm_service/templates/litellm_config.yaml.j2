general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY
  store_model_in_db: True

model_list:
{% for alias, route in lock.deployment.gateways.litellm.routes.items() %}
{% set max_model_len = route.max_model_len or 4096 %}
{% set max_output = max_model_len // 2 %}
{% set max_input = max_model_len - max_output %}
  - model_name: {{ alias }}
    litellm_params:
{% if route.provider == 'ollama' %}
      model: ollama_chat/{{ route.upstream_model }}
      api_base: http://ollama:11434
      drop_params: true
{% elif route.protocol_mode == 'completions' %}
      model: text-completion-openai/{{ route.served_model_name }}
      api_base: http://{{ route.upstream_service_name or route.service_name }}:8000/v1
      api_key: os.environ/VLLM_BACKEND_API_KEY
{% else %}
      model: openai/{{ route.served_model_name }}
      api_base: http://{{ route.upstream_service_name or route.service_name }}:8000/v1
      api_key: os.environ/VLLM_BACKEND_API_KEY
      merge_reasoning_content_in_choices: true
{% endif %}
{% if route.chat_compat_enabled and route.chat_compat_strategy == 'flat_messages' %}
      initial_prompt_value: ""
      roles:
        system:
          pre_message: ""
          post_message: "\n"
        user:
          pre_message: ""
          post_message: "\n"
        assistant:
          pre_message: ""
          post_message: "\n"
      final_prompt_value: ""
{% endif %}
    model_info:
      max_tokens: {{ max_model_len }}
      max_input_tokens: {{ max_input }}
      max_output_tokens: {{ max_output }}
{% endfor %}
