general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY

model_list:
{% for alias, target in lock.deployment.router.aliases.items() %}
{% set svc = (lock.deployment.services | selectattr('service_name', 'equalto', target) | first) %}
  - model_name: {{ alias }}
    litellm_params:
{% if svc.protocol_mode == "completions" %}
      model: text-completion-openai/{{ svc.served_model_name }}
{% else %}
      model: openai/{{ svc.served_model_name }}
{% endif %}
      api_base: http://vllm-{{ svc.service_name }}:8000/v1
      api_key: os.environ/VLLM_BACKEND_API_KEY
{% if svc.protocol_mode != "completions" %}
      merge_reasoning_content_in_choices: true
{% endif %}
{% if svc.chat_compat_enabled and svc.chat_compat_strategy == "flat_messages" %}
      # chat_compat: flat_messages
      # Flatten chat-shaped requests into a plain prompt for completions-only
      # upstreams. No role labels; messages are concatenated with newlines.
      initial_prompt_value: ""
      roles:
        system:
          pre_message: ""
          post_message: "\n"
        user:
          pre_message: ""
          post_message: "\n"
        assistant:
          pre_message: ""
          post_message: "\n"
      final_prompt_value: ""
{% endif %}
{% endfor %}
