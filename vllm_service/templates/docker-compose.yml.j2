services:
{% if lock.deployment.frontends.open_webui.enabled %}
  postgres-open-webui:
    image: {{ lock.deployment.images.postgres }}
    container_name: postgres-open-webui
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${OPENWEBUI_POSTGRES_DB}
      POSTGRES_USER: ${OPENWEBUI_POSTGRES_USER}
      POSTGRES_PASSWORD: ${OPENWEBUI_POSTGRES_PASSWORD}
    volumes:
      - {{ lock.deployment.state.postgres_open_webui }}:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $$POSTGRES_USER -d $$POSTGRES_DB"]
      interval: 10s
      timeout: 5s
      retries: 10

{% endif %}
{% if lock.deployment.gateways.litellm.enabled %}
  postgres-litellm:
    image: {{ lock.deployment.images.postgres }}
    container_name: postgres-litellm
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${LITELLM_POSTGRES_DB}
      POSTGRES_USER: ${LITELLM_POSTGRES_USER}
      POSTGRES_PASSWORD: ${LITELLM_POSTGRES_PASSWORD}
    volumes:
      - {{ lock.deployment.state.postgres_litellm }}:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $$POSTGRES_USER -d $$POSTGRES_DB"]
      interval: 10s
      timeout: 5s
      retries: 10

{% endif %}
{% if lock.deployment.providers.ollama.enabled %}
  ollama:
    image: {{ lock.deployment.images.ollama }}
    container_name: ollama
    restart: unless-stopped
    environment:
      NVIDIA_DRIVER_CAPABILITIES: compute,utility
      CUDA_VISIBLE_DEVICES: "{{ lock.deployment.providers.ollama.gpu_indices | join(',') }}"
      OLLAMA_HOST: "{{ lock.deployment.providers.ollama.host }}"
      OLLAMA_KEEP_ALIVE: "{{ lock.deployment.providers.ollama.keep_alive }}"
      OLLAMA_CONTEXT_LENGTH: "{{ lock.deployment.providers.ollama.context_length }}"
      OLLAMA_NUM_PARALLEL: "{{ lock.deployment.providers.ollama.num_parallel }}"
      OLLAMA_MAX_LOADED_MODELS: "{{ lock.deployment.providers.ollama.max_loaded_models }}"
      OLLAMA_MAX_QUEUE: "{{ lock.deployment.providers.ollama.max_queue }}"
    volumes:
      - {{ lock.deployment.state.ollama }}:/root/.ollama
{% if lock.deployment.providers.ollama.publish_port %}
    ports:
      - "127.0.0.1:{{ lock.deployment.ports.ollama }}:11434"
{% endif %}
    healthcheck:
      test: ["CMD-SHELL", "ollama list >/dev/null 2>&1 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 30
      start_period: 60s
{% if lock.deployment.providers.ollama.gpu_indices %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              device_ids: [{% for idx in lock.deployment.providers.ollama.gpu_indices %}"{{ idx }}"{% if not loop.last %}, {% endif %}{% endfor %}]
              capabilities: [gpu]
{% endif %}

{% endif %}
{% for name, svc in lock.deployment.providers.vllm.runtimes.items() %}
  {{ svc.compose_service_name }}:
    image: {{ lock.deployment.images.vllm }}
    container_name: {{ svc.container_name or svc.compose_service_name }}
    restart: unless-stopped
    ipc: host
    labels:
      vllm_service.profile_name: "{{ svc.profile_name }}"
      vllm_service.public_name: "{{ svc.profile_public_name }}"
      vllm_service.logical_model_name: "{{ svc.logical_model_name }}"
      vllm_service.protocol_mode: "{{ svc.protocol_mode }}"
    environment:
      NVIDIA_DRIVER_CAPABILITIES: compute,utility
      HF_TOKEN: ${HF_TOKEN}
      VLLM_API_KEY: ${VLLM_BACKEND_API_KEY}
      HF_HOME: /root/.cache/huggingface
      HF_HUB_CACHE: /root/.cache/huggingface/hub
      HUGGINGFACE_HUB_CACHE: /root/.cache/huggingface/hub
      VLLM_CACHE_ROOT: /root/.cache/vllm
      TORCH_HOME: /root/.cache/torch
      TORCHINDUCTOR_CACHE_DIR: /root/.cache/torch/inductor
      TRITON_CACHE_DIR: /root/.cache/triton
      CUDA_CACHE_PATH: /root/.cache/nvidia/ComputeCache
{% if lock.deployment.vllm.enable_responses_api_store %}
      VLLM_ENABLE_RESPONSES_API_STORE: "1"
{% endif %}
      VLLM_LOGGING_LEVEL: "{{ lock.deployment.vllm.logging_level }}"
    command:
      - "{{ svc.hf_model_id }}"
      - --host
      - 0.0.0.0
      - --port
      - "8000"
      - --api-key
      - ${VLLM_BACKEND_API_KEY}
      - --served-model-name
      - "{{ svc.served_model_name }}"
      - --tensor-parallel-size
      - "{{ svc.tensor_parallel_size }}"
      - --data-parallel-size
      - "{{ svc.data_parallel_size }}"
      - --max-model-len
      - "{{ svc.max_model_len }}"
      - --gpu-memory-utilization
      - "{{ svc.gpu_memory_utilization }}"
      - --max-num-batched-tokens
      - "{{ svc.max_num_batched_tokens }}"
      - --max-num-seqs
      - "{{ svc.max_num_seqs }}"
{% if svc.enable_prefix_caching %}
      - --enable-prefix-caching
{% endif %}
{% if svc.enable_auto_tool_choice %}
      - --enable-auto-tool-choice
      - --tool-call-parser
      - "{{ svc.tool_call_parser }}"
{% endif %}
{% if svc.reasoning_enabled and svc.reasoning_parser %}
      - --reasoning-parser
      - "{{ svc.reasoning_parser }}"
{% endif %}
{% for extra_arg in svc.extra_args %}
      - "{{ extra_arg }}"
{% endfor %}
    volumes:
      - {{ lock.deployment.state.hf_cache }}:/root/.cache/huggingface
      - {{ lock.deployment.state.vllm_cache }}:/root/.cache/vllm
      - {{ lock.deployment.state.torch_cache }}:/root/.cache/torch
      - {{ lock.deployment.state.triton_cache }}:/root/.cache/triton
      - {{ lock.deployment.state.cuda_cache }}:/root/.cache/nvidia/ComputeCache
    ports:
      - "127.0.0.1:{{ svc.host_port or (18000 + loop.index0) }}:8000"
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8000/health >/dev/null 2>&1 || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 30
      start_period: 1800s
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              device_ids: [{% for idx in svc.gpu_indices %}"{{ idx }}"{% if not loop.last %}, {% endif %}{% endfor %}]
              capabilities: [gpu]

{% endfor %}
{% if lock.deployment.gateways.litellm.enabled %}
  litellm:
    image: {{ lock.deployment.images.litellm }}
    container_name: litellm
    restart: unless-stopped
    depends_on:
      postgres-litellm:
        condition: service_healthy
    # Do not depend directly on provider health here. LiteLLM can load its
    # route table before upstream providers are healthy, and avoiding provider
    # dependency edges prevents Compose from restarting LiteLLM on every vLLM
    # model swap. Smoke tests and clients should retry until the selected
    # upstream model is healthy.
    environment:
      LITELLM_MASTER_KEY: ${LITELLM_MASTER_KEY}
      VLLM_BACKEND_API_KEY: ${VLLM_BACKEND_API_KEY}
      DATABASE_URL: postgresql://${LITELLM_POSTGRES_USER}:${LITELLM_POSTGRES_PASSWORD}@postgres-litellm:5432/${LITELLM_POSTGRES_DB}
    command:
      - --config
      - /app/config.yaml
      - --port
      - "4000"
      - --num_workers
      - "1"
    volumes:
      - {{ lock.deployment.state.runtime }}/litellm_config.yaml:/app/config.yaml:ro
    ports:
      - "{{ lock.deployment.ports.litellm }}:4000"

{% endif %}
{% if lock.deployment.frontends.open_webui.enabled %}
  open-webui:
    image: {{ lock.deployment.images.open_webui }}
    container_name: open-webui
    restart: unless-stopped
    depends_on:
      postgres-open-webui:
        condition: service_healthy
    environment:
      WEBUI_AUTH: "{{ 'True' if lock.deployment.frontends.open_webui.auth else 'False' }}"
      ENABLE_PERSISTENT_CONFIG: "False"
      DATABASE_URL: postgresql://${OPENWEBUI_POSTGRES_USER}:${OPENWEBUI_POSTGRES_PASSWORD}@postgres-open-webui:5432/${OPENWEBUI_POSTGRES_DB}
{% if lock.deployment.frontends.open_webui.provider == 'ollama' %}
      ENABLE_OLLAMA_API: "True"
      OLLAMA_BASE_URL: http://ollama:11434
{% elif lock.deployment.frontends.open_webui.provider == 'litellm' %}
      ENABLE_OLLAMA_API: "False"
      OPENAI_API_BASE_URL: http://litellm:4000/v1
      OPENAI_API_KEY: ${LITELLM_MASTER_KEY}
{% endif %}
      WEBUI_SECRET_KEY: ${WEBUI_SECRET_KEY}
    volumes:
      - {{ lock.deployment.state.open_webui }}:/app/backend/data
    ports:
      - "{{ lock.deployment.ports.open_webui }}:8080"
{% endif %}
